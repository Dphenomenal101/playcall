# ---------------------------------------------------------------------------
# Supabase (required)
# Project Settings -> API in your Supabase dashboard
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Vercel Blob (required for audio call recordings and playbook source-document uploads)
# Both go directly from the browser to Vercel Blob, bypassing the 4.5 MB
# serverless body-size limit.
# Vercel Dashboard -> Storage -> Create -> Blob -> connect to this project.
# Vercel auto-injects this when connected; `vercel env pull .env.local` to
# get it locally.
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Secrets encryption (required)
# Encrypts per-workspace BYOK provider credentials at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
# ---------------------------------------------------------------------------
WORKSPACE_SECRETS_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Vercel Cron (optional, recommended)
# Protects /api/cron/keep-alive (prevents Supabase's 7-day inactivity pause
# on the free tier). Any random 16+ char string.
# ---------------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------------
# LlamaParse (required for rich document parsing)
# Handles PDF, DOCX, PPTX, images, and complex visual layouts — used for
# both playbook source-document ingestion and rep transcript uploads (when
# the rep uploads a PDF/DOCX/PPTX instead of pasting text or uploading audio).
# App-level fallback - workspaces can also bring their own key via Settings.
# Get a free API key at https://cloud.llamaindex.ai
# ---------------------------------------------------------------------------
LLAMA_CLOUD_API_KEY=

# Webhook secret - any random string, used to verify LlamaParse callbacks.
# Generate with: openssl rand -hex 32
LLAMA_CLOUD_WEBHOOK_SECRET=

# Webhook URL - the public URL LlamaParse should POST results to.
# In local dev: your ngrok URL (e.g. https://abc123.ngrok.io)
# In production: set automatically from NEXT_PUBLIC_APP_URL
LLAMA_CLOUD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# AI providers
# App-level fallback credentials, same BYOK rule as above - blank is fine if
# every workspace configures its own provider keys.
# OpenAI is also required for audio call transcription (Whisper).
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Enrichment (pick one; workspaces can also bring their own key via Settings)
# Required for call scoring — looks up buyer/company context before scoring.
# A missing enrichment provider causes buyer_enrichment jobs to throw, which
# breaks the full scoring pipeline.
#
# Option A — Exa (web search + neural search)
# https://dashboard.exa.ai/api-keys
# ---------------------------------------------------------------------------
EXA_API_KEY=

# Option B — TheHog (company search + contact enrichment)
# Get credentials at https://docs.thehog.ai
# Note: if EXA_API_KEY is also set, Exa takes priority as the env fallback.
# Set one or the other, or configure per-workspace via Settings -> Integrations.
THEHOG_ACCESS_KEY=
THEHOG_SECRET_KEY=
